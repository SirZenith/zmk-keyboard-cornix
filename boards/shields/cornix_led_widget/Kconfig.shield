config SHIELD_CORNIX_LED_WIDGET
    def_bool $(shields_list_contains,cornix_led_widget)

# Color definitions to use with color settings
COLOR_BLACK   := 0
COLOR_RED     := 1
COLOR_GREEN   := 2
COLOR_YELLOW  := 3
COLOR_BLUE    := 4
COLOR_MAGENTA := 5
COLOR_CYAN    := 6
COLOR_WHITE   := 7

config LED_WIDGET
    bool "Enable RGB LED widget for showing battery and output status"

if LED_WIDGET

config LED_WIDGET_LED_COUNT
    int "Number of LEDs in the strip"
    range 1 4
    default 2
    help
      Number of addressable LEDs in the WS2812 strip. Maximum 4 LEDs
      are supported for optimal performance and memory usage.

config LED_WIDGET_BRIGHTNESS
    int "Default LED brightness (0-255)"
    range 0 255
    default 128
    help
      Default brightness level for WS2812 LEDs. Lower values reduce
      power consumption and eye strain.

config CHARGING_LED_INDEX
    int "LED index for charging status"
    default 0
    help
      Index of the LED used to indicate charging status. Set to -1 to disable.

endif # LED_WIDGET